#!/usr/bin/with-contenv bashio
# ==============================================================================
# Start the Strava Training Platform
# ==============================================================================

bashio::log.info "Starting Strava Training Platform..."

# Set data path
export DATA_PATH="/data/strava_training"
mkdir -p "${DATA_PATH}"

cd /app

exec python3 -m uvicorn backend.main:app \
    --host 0.0.0.0 \
    --port 8080 \
    --workers 1 \
    --log-level info
